[package]
name = "{{project-name}}"
version = "0.1.0"
authors = ["{{author_name}} <{{author_email}}>"]
edition = "2024"
description = "{{project_description}}"
license = "MIT"
repository = "https://github.com/{{author_name}}/{{project-name}}"
keywords = ["rust", "service"]
categories = ["development-tools"]

[dependencies]
{%- if use_cli or use_settings or use_logging or use_tracing or use_jemalloc %}
foundations = { version = "*", features = [
    {%- if use_cli %}"cli",{% endif -%}
    {%- if use_settings %}"settings",{% endif -%}
    {%- if use_logging or use_tracing %}"telemetry",{% endif -%}
    {%- if use_jemalloc %}"jemalloc",{% endif -%}
] }
{%- endif %}
{%- if use_logging or use_tracing %}
tokio = { version = "*", features = ["rt-multi-thread", "macros"] }
{%- endif %}

[dev-dependencies]
anyhow = "*"
{%- if use_logging or use_tracing %}
tokio = { version = "*", features = ["rt-multi-thread", "macros"] }
{%- endif %}

[profile.release]
opt-level = 3
lto = true
codegen-units = 1
strip = true

[profile.dev]
opt-level = 0
debug = true
