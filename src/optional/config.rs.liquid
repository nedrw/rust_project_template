{%- if use_config %}
use serde::Deserialize;
use std::path::Path;
use std::sync::OnceLock;

pub static CONFIG: OnceLock<AppConfig> = OnceLock::new();

/// 应用配置
#[derive(Deserialize, Debug, Clone)]
pub struct AppConfig {
    /// 应用名称
    #[serde(default = "default_app_name")]
    pub app_name: String,

    {%- if use_logging %}

    /// 日志配置
    pub log: LogConfig,
    {%- endif %}

    /// 其他自定义配置（扩展字段）
    #[serde(flatten)]
    pub extra: Option<serde_json::Value>,
}

fn default_app_name() -> String {
    "{{project-name}}".to_string()
}

{%- if use_logging %}

/// 日志配置（适配 tracing）
#[derive(Deserialize, Debug, Clone)]
pub struct LogConfig {
    /// 日志级别: trace, debug, info, warn, error
    #[serde(default = "default_log_level")]
    pub level: String,

    /// 日志文件存放目录
    #[serde(default = "default_log_dir")]
    pub dir: String,

    /// 日志文件名前缀
    #[serde(default = "default_log_prefix")]
    pub prefix: String,

    /// 最大日志文件数量
    #[serde(default = "default_max_files")]
    pub max_files: usize,

    /// 是否同时输出到控制台
    #[serde(default = "default_console")]
    pub console: bool,

    /// 是否使用 JSON 格式（生产环境推荐）
    #[serde(default)]
    pub json: bool,
}

fn default_log_level() -> String {
    "info".to_string()
}

fn default_log_dir() -> String {
    "./logs".to_string()
}

fn default_log_prefix() -> String {
    "{{project-name}}".to_string()
}

fn default_max_files() -> usize {
    10
}

fn default_console() -> bool {
    true
}

impl Default for LogConfig {
    fn default() -> Self {
        Self {
            level: default_log_level(),
            dir: default_log_dir(),
            prefix: default_log_prefix(),
            max_files: default_max_files(),
            console: default_console(),
            json: false,
        }
    }
}
{%- endif %}

impl Default for AppConfig {
    fn default() -> Self {
        Self {
            app_name: default_app_name(),
            {%- if use_logging %}
            log: LogConfig::default(),
            {%- endif %}
            extra: None,
        }
    }
}

/// 从文件加载配置
pub fn load_config<P: AsRef<Path>>(path: P) -> Result<AppConfig, Box<dyn std::error::Error>> {
    let content = std::fs::read_to_string(path.as_ref())?;

    {%- if config_format == "toml" %}

    let config: AppConfig = toml::from_str(&content)?;
    {%- endif %}

    {%- if config_format == "yaml" %}

    let config: AppConfig = serde_yaml::from_str(&content)?;
    {%- endif %}

    {%- if config_format == "json" %}

    let config: AppConfig = serde_json::from_str(&content)?;
    {%- endif %}

    Ok(config)
}

/// 初始化全局配置
pub fn init_config(path: &str) -> &'static AppConfig {
    CONFIG.get_or_init(|| {
        load_config(path).unwrap_or_else(|e| {
            eprintln!("Failed to load config from {}: {}", path, e);
            eprintln!("Using default configuration");
            AppConfig::default()
        })
    })
}

/// 获取全局配置
pub fn config() -> &'static AppConfig {
    CONFIG.get().expect("Config not initialized. Call init_config() first.")
}
{%- else %}

// 当不使用配置功能时，提供空实现
pub struct AppConfig;

pub fn init_config(_path: &str) -> &'static AppConfig {
    &AppConfig
}

pub fn config() -> &'static AppConfig {
    &AppConfig
}
{%- endif %}

#[cfg(test)]
mod tests {
    use super::*;

    {%- if use_config %}

    #[test]
    fn test_default_config() {
        let config = AppConfig::default();
        assert_eq!(config.app_name, "{{project-name}}");

        {%- if use_logging %}

        assert_eq!(config.log.level, "info");
        assert_eq!(config.log.dir, "./logs");
        {%- endif %}
    }

    #[test]
    fn test_load_nonexistent_config() {
        let config = load_config("nonexistent.toml");
        assert!(config.is_err());
    }
    {%- endif %}
}
