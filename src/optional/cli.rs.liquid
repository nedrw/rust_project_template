use clap::{Parser, Subcommand};

/// {{project_description}}
#[derive(Parser, Debug)]
#[command(
    name = "{{project-name}}",
    author = "{{author_name}} <{{author_email}}>",
    version = "0.1.0",
    about = "{{project_description}}",
    long_about = "{{project_description}}\n\nAuthor: {{author_name}}\nRepository: https://github.com/{{author_name}}/{{project-name}}"
)]
pub struct CliArgs {
    /// 配置文件路径
    #[arg(short, long, global = true, env = "APP_CONFIG")]
    pub config: Option<String>,

    /// 日志级别
    #[arg(short, long, global = true, env = "APP_LOG_LEVEL")]
    pub log_level: Option<String>,

    /// 子命令
    #[command(subcommand)]
    pub command: Option<Commands>,
}

/// 子命令定义
#[derive(Subcommand, Debug)]
pub enum Commands {
    /// 显示版本信息
    #[command(alias = "v")]
    Version,

    /// 显示应用信息
    #[command(alias = "i")]
    Info,

    /// 检查配置文件
    #[command(alias = "c")]
    Check {
        /// 配置文件路径
        #[arg(short, long)]
        path: Option<String>,
    },

    /// 运行示例
    #[command(alias = "e")]
    Example {
        /// 示例名称
        #[arg(short, long)]
        name: Option<String>,
    },
}

/// 解析命令行参数
pub fn parse_args() -> CliArgs {
    CliArgs::parse()
}

/// 打印欢迎信息
pub fn print_banner() {
    println!();
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║                                                          ║");
    println!("║   {{project-name}}                                    ║");
    println!("║                                                          ║");
    println!("║   Version: 0.1.0                                         ║");
    println!("║   Author: {{author_name}}                                 ║");
    println!("║                                                          ║");
    println!("╚══════════════════════════════════════════════════════════╝");
    println!();
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_cli_args_default() {
        let args = CliArgs::try_parse_from(["{{project-name}}"]);
        assert!(args.is_ok());
        let args = args.unwrap();
        assert!(args.config.is_none());
        assert!(args.command.is_none());
    }

    #[test]
    fn test_cli_args_with_config() {
        let args = CliArgs::try_parse_from(["{{project-name}}", "--config", "test.toml"]);
        assert!(args.is_ok());
        let args = args.unwrap();
        assert_eq!(args.config, Some("test.toml".to_string()));
    }

    #[test]
    fn test_cli_args_version_command() {
        let args = CliArgs::try_parse_from(["{{project-name}}", "version"]);
        assert!(args.is_ok());
        let args = args.unwrap();
        assert!(matches!(args.command, Some(Commands::Version)));
    }

    #[test]
    fn test_cli_args_info_command() {
        let args = CliArgs::try_parse_from(["{{project-name}}", "info"]);
        assert!(args.is_ok());
        let args = args.unwrap();
        assert!(matches!(args.command, Some(Commands::Info)));
    }
}

// CLI 设计说明：
//
// 1. 使用 clap 的 derive 宏简化命令行参数解析
// 2. 支持全局参数
// 3. 支持子命令
// 4. 支持环境变量配置
// 5. 提供友好的帮助信息和版本信息
// 6. 支持命令别名（如 version 命令可以使用 v）
//
// 使用示例：
// ```bash
// # 显示帮助
// {{project-name}} --help
//
// # 指定配置文件
// {{project-name}} --config custom.toml
//
// # 设置日志级别
// {{project-name}} --log-level debug
//
// # 使用子命令
// {{project-name}} version
// {{project-name}} info
// {{project-name}} check --path config/test.toml
// {{project-name}} example --name demo
// ```
//
// 子命令扩展：
// 你可以根据需要添加更多子命令，例如：
// - start: 启动服务
// - stop: 停止服务
// - status: 查看状态
// - restart: 重启服务
// - log: 日志相关命令（需要启用 use_logging）
// - config: 配置相关命令（需要启用 use_config）
// - migrate: 数据库迁移
// - serve: 启动 Web 服务器
// - worker: 启动后台任务
//
// 添加新命令的步骤：
// 1. 在 Commands 枚举中添加新的变体
// 2. 在 main.rs 的 handle_subcommand 函数中处理新命令
// 3. 实现命令的具体逻辑
